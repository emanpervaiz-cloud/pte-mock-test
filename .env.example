# Environment Variables for PTE Mock Test Application

# OpenAI API Key for AI evaluation
VITE_OPENAI_API_KEY=

# OpenRouter API Key (alternative to OpenAI)
VITE_OPENROUTER_API_KEY=

# n8n Webhook URL for results submission
VITE_WEBHOOK_URL=

# Optional: Custom API endpoints
VITE_AI_EVALUATION_API_URL=https://api.openai.com/v1/chat/completions
VITE_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
VITE_AUDIO_RECORDING_FORMAT=audio/webm